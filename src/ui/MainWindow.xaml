<Window x:Class="diskform4th.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding LocalizedStrings[app_name]}" Height="550" Width="450"
        Background="#1E1E1E" Foreground="White" WindowStyle="None" ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="StartButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="0,15"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0063B1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header / Title Bar -->
            <RowDefinition Height="Auto"/> <!-- Device Selection -->
            <RowDefinition Height="Auto"/> <!-- Boot Selection -->
            <RowDefinition Height="Auto"/> <!-- Image Mode -->
            <RowDefinition Height="Auto"/> <!-- Cloud Fetch -->
            <RowDefinition Height="Auto"/> <!-- Format Options -->
            <RowDefinition Height="*"/>    <!-- Spacer -->
            <RowDefinition Height="Auto"/> <!-- Progress & Status -->
            <RowDefinition Height="Auto"/> <!-- Start Button & Language -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding LocalizedStrings[app_name]}" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <!-- S.M.A.R.T Temperature Display -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Drive Temp: " Foreground="#888888" VerticalAlignment="Center"/>
                <TextBlock x:Name="TempTextBlock" Text="--°C" Foreground="#0078D7" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Device Selection -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding LocalizedStrings[select_device]}"/>
            <ComboBox x:Name="DeviceComboBox"/>
        </StackPanel>

        <!-- Boot Selection -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="{Binding LocalizedStrings[boot_selection]}"/>
            <Grid Margin="0,5,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="IsoPathTextBox" Grid.Column="0" Height="32" IsReadOnly="True" Background="#2D2D30" Foreground="White" VerticalContentAlignment="Center" Padding="10,0" Text="SELECT ISO IMAGE..." BorderThickness="1" BorderBrush="#444444"/>
                <Button Grid.Column="1" Content="..." Width="45" Height="32" Margin="10,0,0,0" Style="{StaticResource ModernButton}" Click="SelectIsoButton_Click"/>
            </Grid>
        </StackPanel>

        <!-- Image Mode Selection -->
        <StackPanel Grid.Row="3" Margin="0,5,0,15">
            <TextBlock Text="Image Mode"/>
            <ComboBox x:Name="ImageModeComboBox">
                <ComboBoxItem Content="ISO Image Mode (Recommended)" IsSelected="True" Tag="ISO"/>
                <ComboBoxItem Content="DD Image Mode" Tag="DD"/>
                <ComboBoxItem Content="Multi-Boot Mode (Ventoy Alternative)" Tag="MULTI"/>
            </ComboBox>
        </StackPanel>

        <!-- Cloud Fetch -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="{Binding LocalizedStrings[cloud_iso]}"/>
            <Grid Margin="0,5,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="CloudIsoComboBox" Grid.Column="0" Margin="0" Height="32">
                    <ComboBoxItem Content="Ubuntu 24.04 Desktop" Tag="https://releases.ubuntu.com/24.04/ubuntu-24.04-desktop-amd64.iso"/>
                    <ComboBoxItem Content="Alpine Linux 3.19.1" Tag="https://dl-cdn.alpinelinux.org/alpine/v3.19/releases/x86_64/alpine-standard-3.19.1-x86_64.iso"/>
                </ComboBox>
                <Button Grid.Column="1" Content="FETCH" Width="70" Height="32" Margin="10,0,0,0" Style="{StaticResource ModernButton}" Click="FetchIsoButton_Click"/>
            </Grid>
        </StackPanel>

        <!-- Advanced Security & Performance Options -->
        <StackPanel Grid.Row="5">
            <TextBlock Text="Forensic Security &amp; Extreme Performance" FontSize="16" Foreground="White" Margin="0,10,0,10"/>

            <UniformGrid Columns="2" Margin="0,5">
                <CheckBox x:Name="VerifyCheckBox" Content="Verify Blocks (SHA-256/GPU)" Foreground="White" Margin="0,5" IsChecked="True"/>
                <CheckBox x:Name="PreloadRamCheckBox" Content="Pre-load ISO to RAM Cache" Foreground="White" Margin="0,5"/>
                <CheckBox x:Name="SecureEraseCheckBox" Content="Secure Erase (DoD 3-Pass Wipe)" Foreground="Red" Margin="0,5"/>
                <CheckBox x:Name="EncryptSpaceCheckBox" Content="Encrypt Free Space (BitLocker/LUKS)" Foreground="White" Margin="0,5"/>
                <CheckBox x:Name="PersistenceCheckBox" Content="Persistent Partition (casper-rw)" Foreground="White" Margin="0,5"/>
                <Button x:Name="PxeServerButton" Content="Start PXE Server" Margin="0,5,10,5" Style="{StaticResource ModernButton}" Click="PxeServerButton_Click"/>
            </UniformGrid>
            <Button x:Name="BackupButton" Content="Backup Drive (Reverse Clone to .img.gz)" Margin="0,5,0,0" Style="{StaticResource ModernButton}" Background="#555555" Click="BackupButton_Click"/>
        </StackPanel>

        <!-- Progress & Status -->
        <StackPanel Grid.Row="7" Margin="0,0,0,20">
            <Grid Margin="0,0,0,5">
                <TextBlock x:Name="StatusTextBlock" Text="{Binding LocalizedStrings[status_ready]}" HorizontalAlignment="Left" Foreground="#888888"/>
                <TextBlock x:Name="SpeedTextBlock" Text="0 MB/s" HorizontalAlignment="Right" Foreground="#0078D7" FontWeight="Bold"/>
            </Grid>
            <ProgressBar x:Name="WriteProgressBar" Height="12" Minimum="0" Maximum="100" Value="0" Foreground="#0078D7" Background="#333333" BorderThickness="0" CornerRadius="3"/>
            <TextBlock x:Name="TimeTextBlock" Text="Remaining: --:--" HorizontalAlignment="Right" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Start Button & Language (Bottom Corner) -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Language Toggle (Bottom Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,5">
                <TextBlock Text="EN" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,5,0" Cursor="Hand" MouseLeftButtonUp="LanguageEN_Click"/>
                <TextBlock Text="|" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="TR" Foreground="#888888" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="LanguageTR_Click"/>
            </StackPanel>

            <!-- Large Start Button (Center/Right) -->
            <Button x:Name="StartButton" Grid.Column="1" Content="{Binding LocalizedStrings[start]}" Style="{StaticResource StartButton}" Margin="20,0,0,0" Click="StartButton_Click"/>
        </Grid>
    </Grid>
</Window>